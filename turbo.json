{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "eslint.config.js",
    "playwright.config.ts",
    "tsconfig.base.json",
    "vitest.config.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "storybook-static/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "clean": {
      "cache": false
    },
    "pack:check": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
