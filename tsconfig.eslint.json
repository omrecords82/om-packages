{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": [
    "*.config.js",
    "*.config.ts",
    "apps/**/.storybook/**/*.ts",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**",
    "**/storybook-static/**",
    "**/.turbo/**",
    "**/.tsbuildinfo/**"
  ]
}
