{
  "name": "@om/tokens",
  "version": "0.0.0",
  "private": true,
  "description": "Bootstrap-only token exports for Orthodox Metrics packages.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./manifest": "./dist/manifest.json",
    "./metadata": "./dist/metadata.json",
    "./css": "./dist/css/om-tokens.css",
    "./css/primitives": "./dist/css/om-primitives.css",
    "./css/light": "./dist/css/om-tokens.light.css",
    "./css/dark": "./dist/css/om-tokens.dark.css",
    "./css/liturgical": "./dist/css/om-liturgical.css",
    "./css/accessibility": "./dist/css/om-accessibility.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist .tsbuildinfo && tsc -b && corepack pnpm generate:artifacts && corepack pnpm validate:artifacts",
    "clean": "rm -rf dist .tsbuildinfo",
    "generate:artifacts": "tsx scripts/generate-artifacts.ts",
    "validate:artifacts": "tsx scripts/validate-artifacts.ts",
    "check:artifacts": "tsx scripts/check-artifacts.ts",
    "lint": "eslint .",
    "pack:check": "corepack pnpm pack --dry-run",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --pretty false",
    "validate:tokens": "tsx scripts/validate-token-files.ts",
    "validate:brand": "tsx scripts/validate-brand-pack.ts",
    "validate:references": "tsx scripts/validate-references.ts",
    "validate:policy": "tsx scripts/validate-policy.ts",
    "validate:phase1a": "corepack pnpm --filter @om/contracts build && corepack pnpm validate:tokens && corepack pnpm validate:brand && corepack pnpm validate:references && corepack pnpm validate:policy"
  },
  "dependencies": {
    "@om/contracts": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "zod": "^4.1.13"
  }
}
