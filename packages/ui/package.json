{
  "name": "@om/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Bootstrap-only React integration package for Orthodox Metrics UI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./icon-button": {
      "types": "./dist/icon-button/index.d.ts",
      "import": "./dist/icon-button/index.js"
    },
    "./link": {
      "types": "./dist/link/index.d.ts",
      "import": "./dist/link/index.js"
    },
    "./css": "./dist/styles/index.css"
  },
  "sideEffects": [
    "./dist/styles/*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist .tsbuildinfo && tsc -b && pnpm copy:css && pnpm verify:public-api",
    "clean": "rm -rf dist .tsbuildinfo",
    "copy:css": "mkdir -p dist/styles && cp src/styles/button.css src/styles/link.css dist/styles/ && cat src/styles/button.css src/styles/link.css > dist/styles/index.css",
    "lint": "eslint .",
    "pack:check": "pnpm pack --dry-run",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --pretty false",
    "verify:public-api": "tsx scripts/verify-public-api.ts"
  },
  "dependencies": {
    "@om/contracts": "workspace:*",
    "@om/tokens": "workspace:*",
    "react-aria-components": "1.19.0"
  },
  "peerDependencies": {
    "react": ">=18.3.0 <20",
    "react-dom": ">=18.3.0 <20"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "jsdom": "29.1.1",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
