{
  "name": "@om/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Bootstrap-only React integration package for Orthodox Metrics UI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist .tsbuildinfo && tsc -b",
    "clean": "rm -rf dist .tsbuildinfo",
    "lint": "eslint .",
    "pack:check": "pnpm pack --dry-run",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@om/contracts": "workspace:*",
    "@om/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3.0 <20",
    "react-dom": ">=18.3.0 <20"
  },
  "devDependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
