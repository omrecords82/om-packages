{
  "name": "@om/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Bootstrap-only shared contracts for Orthodox Metrics packages.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist .tsbuildinfo && tsc -b",
    "clean": "rm -rf dist .tsbuildinfo",
    "lint": "eslint .",
    "pack:check": "pnpm pack --dry-run",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --pretty false"
  }
}
